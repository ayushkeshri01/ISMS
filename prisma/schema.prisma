generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  role          String
  department    String
  companyKey    String?
  isCustom      Boolean   @default(false)
  createdById   String?
  otp           String?
  otpExpiresAt  DateTime?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  company       Company?  @relation(fields: [companyKey], references: [key])
}

model Company {
  id                String              @id @default(cuid())
  key               String              @unique
  name              String
  logo              String?
  certificates      Certificate[]
  complianceHistory ComplianceHistory[]
  controls          Control[]
  evidence          Evidence[]
  users             User[]
  reviewSchedules   ReviewSchedule[]
}

model Control {
  id          String     @id @default(cuid())
  companyId   String
  controlId   String
  label       String
  description String?
  status      String     @default("NOT_STARTED")
  category    String
  subCategory String?
  lastUpdated DateTime   @default(now())
  updatedById String?
  company     Company    @relation(fields: [companyId], references: [id])
  evidence    Evidence[]
  reviewSchedules   ReviewSchedule[]

  @@unique([companyId, controlId])
  @@index([companyId])
  @@index([status])
  @@index([category])
}

model Evidence {
  id             String    @id @default(cuid())
  controlId      String
  companyId      String
  filename       String
  fileType       String
  fileSize       Int
  fileData       Bytes  @db.ByteA
  evidenceType   String
  status         String    @default("PENDING")
  title          String?
  referenceNo    String?
  version        String?
  uploadedById   String
  uploadedByName String
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  dateOfDocument DateTime?
  createdAt      DateTime  @default(now())
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  control        Control   @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([controlId])
  @@index([uploadedById])
  @@index([companyId, status])
  @@index([status])
  @@index([evidenceType])
}

model Certificate {
  id            String    @id @default(cuid())
  companyId     String
  isActive      Boolean   @default(false)
  body          String
  number        String
  validFrom     DateTime
  validTo       DateTime
  scope         String
  surveillance1 DateTime?
  surveillance2 DateTime?
  fileData      Bytes? @db.ByteA
  fileType      String?
  createdAt     DateTime  @default(now())
  company       Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive])
}

model ActivityLog {
  id           String   @id @default(cuid())
  companyKey   String
  userId       String
  userName     String
  userRole     String
  action       String
  controlId    String?
  controlLabel String?
  fromStatus   String?
  toStatus     String?
  details      String?
  isLocal      Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([companyKey])
  @@index([userId])
  @@index([createdAt])
}

model ComplianceHistory {
  id        String  @id @default(cuid())
  companyId String
  month     Int
  year      Int
  score     Int
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, month, year])
}

model LoginAttempt {
  id          String   @id @default(cuid())
  ipAddress   String
  attemptedAt DateTime @default(now())
  success     Boolean
  pinUsed     String?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userId, read])
}

model ReviewSchedule {
  id                 String    @id @default(cuid())
  controlId          String
  companyId          String
  frequency          String    @default("ANNUAL")
  suggestedFrequency String?
  lastReviewedAt     DateTime?
  nextReviewAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  updatedById        String?

  control Control @relation(fields: [controlId], references: [id])
  company Company @relation(fields: [companyId], references: [id])

  reviewHistory ReviewHistory[]

  @@unique([controlId, companyId])
  @@index([companyId])
  @@index([controlId])
  @@index([nextReviewAt])
}

model ReviewHistory {
  id                String   @id @default(cuid())
  reviewScheduleId  String
  controlId         String
  controlLabel      String?
  companyKey        String
  reviewedAt        DateTime @default(now())
  reviewedById      String
  reviewedByName    String
  frequency         String?
  notes             String?

  reviewSchedule ReviewSchedule @relation(fields: [reviewScheduleId], references: [id])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
